# Copy to .env and fill in values
# Environment: development | production
APP_ENV=development

DATABASE_URL=sqlite:///./statistics.db
# For PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/statistics_db

RECOMMENDATION_THRESHOLD=30.0
RECOMMENDATION_TOP_N=5

# Güvenlik (Production'da mutlaka set et)
# Production'da loopback kullan: HOST=127.0.0.1
HOST=0.0.0.0
PORT=8002
DEBUG=true
# İzin verilen origin'ler (virgülle ayrılmış)
ALLOWED_ORIGINS=http://localhost:8080
# Dahili servis API anahtarı — main-server ile aynı değer olmalı
# APP_ENV=production iken zorunludur
INTERNAL_API_KEY=
